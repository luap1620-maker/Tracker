}

var wins = 0, losses = 0, rugs = 0;
var mints = Object.keys(tokens);
for (var m = 0; m < mints.length; m++) {
var pos = tokens[mints[m]];
if (pos.bought > 0 && pos.sold === 0) { rugs++; continue; }
if (pos.bought > 0 && pos.sold > 0) {
var ratio = pos.sold / pos.bought;
if (ratio >= 1.3) wins++;
else if (ratio < 0.7) losses++;
}
}

var total = wins + losses;
var winrate = total > 0 ? (wins / total * 100).toFixed(1) : ‘0.0’;
var rugRate = mints.length > 0 ? (rugs / mints.length * 100).toFixed(1) : ‘0.0’;

return {
wins: wins,
losses: losses,
rugs: rugs,
total: total,
winrate: winrate,
rugRate: rugRate,
recent7d: recent7d,
lastActive: lastActive > 0 ? new Date(lastActive * 1000).toISOString().substring(0, 10) : ‘N/A’,
isActive: lastActive > weekAgo,
};
}

