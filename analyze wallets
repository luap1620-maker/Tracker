async function getBalance(address) {
try {
var res = await axios.post(‘https://mainnet.helius-rpc.com/?api-key=’ + HELIUS_KEY, {
jsonrpc: ‘2.0’, id: 1, method: ‘getBalance’, params: [address]
}, { timeout: 10000 });
var lamports = res.data.result ? res.data.result.value : 0;
return (lamports / 1e9) * SOL_PRICE;
} catch (err) { return 0; }
}

async function getTransactions(address) {
try {
var res = await axios.get(‘https://api.shyft.to/sol/v1/transaction/history’, {
params: { network: ‘mainnet-beta’, account: address, tx_num: 100, enable_raw: false, type: ‘SWAP’ },
headers: { ‘x-api-key’: SHYFT_KEY },
timeout: 20000,
});
return res.data && res.data.success ? res.data.result || [] : [];
} catch (err) { return []; }
}

function analyze(txs, address) {
var tokens = {};
var now = Date.now() / 1000;
var weekAgo = now - (7 * 24 * 3600);
var lastActive = 0;
var recent7d = 0;

for (var t = 0; t < txs.length; t++) {
var tx = txs[t];
if (!tx || !tx.timestamp) continue;
var ts = new Date(tx.timestamp).getTime() / 1000;
if (ts > lastActive) lastActive = ts;
if (ts > weekAgo) recent7d++;

```
var changes = tx.token_balance_changes || [];
for (var c = 0; c < changes.length; c++) {
  var ch = changes[c];
  if (!ch.mint || ch.mint === 'So11111111111111111111111111111111111111112') continue;
  if (!tokens[ch.mint]) tokens[ch.mint] = { bought: 0, sold: 0 };
  if (ch.owner === address) {
    if (ch.change_amount > 0) tokens[ch.mint].bought += ch.change_amount;
    else tokens[ch.mint].sold += Math.abs(ch.change_amount);
  }
}
